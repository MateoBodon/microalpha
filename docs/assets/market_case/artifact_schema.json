{
  "$id": "microalpha.market-risk-case.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "daily_required_columns": [
    "date",
    "signal_available_date",
    "executed_weight",
    "turnover",
    "commission",
    "half_spread",
    "impact",
    "total_cost",
    "strategy_net",
