    "static_risk_matched"
  ],
  "metrics_required": [
    "strategy_net",
    "market",
    "static_risk_matched",
    "selection_control",
    "claim_boundary"
  ],
  "required_artifacts": [
    "metrics.json",
    "daily.csv",
    "folds.csv",
    "selection.json",
    "data_manifest.json",
    "market_case.svg",
    "equity_drawdown.svg",
    "data_lineage.svg"
  ]
}
